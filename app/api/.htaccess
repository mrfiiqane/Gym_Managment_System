# Custom Error Pages
ErrorDocument 403 /Gym_Managment_system/app/views/Errors/403.php
ErrorDocument 404 /Gym_Managment_system/app/views/Errors/404.php
ErrorDocument 500 /Gym_Managment_system/app/views/Errors/500.php

# Security: Prevent directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

<Files "init.php">
    Order allow,deny
    Deny from all
</Files>

